page {
    includeCSS {
        forum = EXT:forumman/Resources/Public/Css/forum.css
        userprofil = EXT:forumman/Resources/Public/Css/userprofil.css
        messages = EXT:forumman/Resources/Public/Css/messages.css
        prism = EXT:forumman/Resources/Public/prism/prism.css
        lastUsers = EXT:forumman/Resources/Public/Css/lastUsers.css
    }
}

[frontend.user.isLoggedIn]
page.includeJSFooter {
    tinymce = EXT:forumman/Resources/Public/Js/tinymce/tinymce.min.js
    forum_editor = EXT:forumman/Resources/Public/Js/tinymce/forum-editor.js
    settings_editors = EXT:forumman/Resources/Public/Js/tinymce/settings-editor.js 
}
[END]
page.includeJSFooter {
    prism = EXT:forumman/Resources/Public/prism/prism.js
}

